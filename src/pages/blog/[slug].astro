---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import {
  getPosts,
  getPostBySlug,
  formatDate,
  stripHtml,
  getFeaturedImage,
  getPostCategories,
  getAuthorName,
} from '../../lib/wordpress';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug);

if (!post) {
  return Astro.redirect('/blog');
}

const featuredImg = getFeaturedImage(post);
const categories = getPostCategories(post);
const author = getAuthorName(post);
const excerpt = stripHtml(post.excerpt.rendered).slice(0, 200);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title.rendered,
  description: excerpt,
  datePublished: post.date,
  dateModified: post.modified,
  author: {
    '@type': 'Person',
    name: author,
    url: 'https://aragrow.me',
  },
  publisher: {
    '@type': 'Organization',
    name: 'AraGrow LLC',
    url: 'https://aragrow.me',
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `https://aragrow.me/blog/${post.slug}` },
  ...(featuredImg ? { image: featuredImg } : {}),
};
---

<Layout
  title={`${post.title.rendered} — AraGrow Blog`}
  description={excerpt}
  structuredData={structuredData}
>
  <Nav />
  <main>
  <div class="post-wrapper">
    <!-- Hero / header -->
    <header class="post-header">
      <div class="container post-header-inner">
        {
          categories.length > 0 && (
            <div class="post-categories">
              {categories.map((cat) => (
                <span class="post-category-tag">{cat}</span>
              ))}
            </div>
          )
        }
        <h1 class="post-title" set:html={post.title.rendered} />
        <div class="post-meta">
          <span class="post-author">By {author}</span>
          <span class="post-sep">·</span>
          <time datetime={post.date}>{formatDate(post.date)}</time>
        </div>
      </div>
    </header>

    <!-- Featured image -->
    {
      featuredImg && (
        <div class="container">
          <div class="post-featured-img">
            <img src={featuredImg} alt={post.title.rendered} />
          </div>
        </div>
      )
    }

    <!-- Post body -->
    <div class="container">
      <article class="post-body" set:html={post.content.rendered} />

      <!-- Back link -->
      <div class="post-back">
        <a href="/blog" class="btn btn-outline">← Back to Blog</a>
        <a href="/#contact" class="btn btn-primary">Work With Me</a>
      </div>
    </div>
  </div>
  </main>

  <Footer />
</Layout>

<style>
  .post-wrapper { padding-top: 80px; padding-bottom: 100px; }

  /* ── Header ── */
  .post-header { padding: 64px 0 40px; }
  .post-header-inner { max-width: 760px; }

  .post-categories { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
  .post-category-tag {
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--teal-text);
    background: var(--teal-dim); border: 1px solid var(--border);
    padding: 4px 12px; border-radius: 50px;
  }

  .post-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700; line-height: 1.2;
    color: var(--text); margin-bottom: 20px;
  }

  .post-meta {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.875rem; color: var(--muted);
  }
  .post-author { font-weight: 500; }
  .post-sep { opacity: 0.4; }

  /* ── Featured image ── */
  .post-featured-img {
    border-radius: var(--radius); overflow: hidden;
    margin-bottom: 48px; max-height: 480px;
    border: 1px solid var(--border);
  }
  .post-featured-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* ── Post body (WordPress content) ── */
  .post-body {
    max-width: 760px;
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text);
  }
  .post-body :global(h2) {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.6rem; font-weight: 700;
    margin: 48px 0 16px; color: var(--text);
  }
  .post-body :global(h3) {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.2rem; font-weight: 600;
    margin: 32px 0 12px; color: var(--text);
  }
  .post-body :global(p) { margin-bottom: 20px; color: var(--text); }
  .post-body :global(a) { color: var(--teal-text); text-decoration: underline; }
  .post-body :global(ul), .post-body :global(ol) {
    margin: 0 0 20px 24px; color: var(--text);
  }
  .post-body :global(li) { margin-bottom: 8px; line-height: 1.7; }
  .post-body :global(blockquote) {
    border-left: 4px solid var(--teal); margin: 32px 0;
    padding: 16px 24px;
    background: var(--teal-dim); border-radius: 0 8px 8px 0;
    font-style: italic; color: var(--muted);
  }
  .post-body :global(pre) {
    background: #0f172a; color: #e2e8f0;
    padding: 24px; border-radius: 8px;
    overflow-x: auto; margin-bottom: 24px;
    font-size: 0.875rem; line-height: 1.7;
  }
  .post-body :global(code) {
    font-family: 'Fira Code', 'Courier New', monospace;
    background: var(--teal-dim); padding: 2px 6px;
    border-radius: 4px; font-size: 0.875em;
  }
  .post-body :global(pre code) { background: none; padding: 0; }
  .post-body :global(img) {
    max-width: 100%; border-radius: 8px;
    border: 1px solid var(--border); margin: 24px 0;
  }
  .post-body :global(table) {
    width: 100%; border-collapse: collapse; margin-bottom: 24px;
  }
  .post-body :global(th), .post-body :global(td) {
    padding: 10px 14px; border: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .post-body :global(th) { background: var(--teal-dim); font-weight: 600; }

  /* ── Back / CTA ── */
  .post-back {
    display: flex; gap: 16px; flex-wrap: wrap;
    margin-top: 64px; padding-top: 40px;
    border-top: 1px solid var(--border);
  }
</style>
