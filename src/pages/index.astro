---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import Testimonials from '../components/Testimonials.astro';
import Blog from '../components/Blog.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'David Arago',
    jobTitle: 'Fractional CTO',
    url: 'https://aragrow.me',
    sameAs: ['https://www.linkedin.com/in/davidarago/'],
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Minneapolis',
      addressRegion: 'MN',
      addressCountry: 'US',
    },
    knowsLanguage: ['en', 'es'],
    worksFor: {
      '@type': 'Organization',
      name: 'AraGrow LLC',
      url: 'https://aragrow.me',
    },
    award: [
      'Emmy Award — Web Site Design & Usability (Upper Midwest Chapter, 2007–2008)',
      'Best in WebOps Award Winner (Pantheon Platform, 2023)',
      'Brooklyn Center Local Business Person of the Year (Alignable, 2025)',
      'Highly Recommended by Locals (Alignable, 2025)',
      'Community Supporter Award (Alignable, 2025)',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'AraGrow LLC',
    url: 'https://aragrow.me',
    slogan: 'Apps for scalable growth',
    description:
      'AraGrow LLC provides fractional CTO services, AI integration, web development, cloud infrastructure, and database management for growing businesses.',
    founder: { '@type': 'Person', name: 'David Arago' },
    areaServed: 'US',
    priceRange: '$75/hour',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Minneapolis',
      addressRegion: 'MN',
      addressCountry: 'US',
    },
    sameAs: ['https://www.linkedin.com/company/112431091/'],
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Technology Services',
      itemListElement: [
        'Fractional CTO',
        'AI Integration',
        'Web Development',
        'Cloud Infrastructure',
        'Database Management',
        'Web Performance & WebOps',
      ].map((name) => ({ '@type': 'Offer', itemOffered: { '@type': 'Service', name } })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'David Arago — AraGrow LLC',
    url: 'https://aragrow.me',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'AraGrow LLC',
    url: 'https://aragrow.me',
    review: [
      {
        '@type': 'Review',
        author: { '@type': 'Person', name: 'Brent Peterson' },
        reviewBody:
          "David Arago is a WordPress development virtuoso who consistently delivers top-notch solutions. His 25+ years of experience shine through in his ability to navigate complex problems with finesse.",
        reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      },
      {
        '@type': 'Review',
        author: { '@type': 'Person', name: 'Christian Kuffner' },
        reviewBody:
          'David Arago is a very professional developer, excellent at creating accurate scopes for PHP development projects.',
        reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      },
      {
        '@type': 'Review',
        author: { '@type': 'Person', name: 'Jack' },
        reviewBody:
          'David is committed to his craft and he is willing to do what I call the R&R – reading and research.',
        reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      },
      {
        '@type': 'Review',
        author: { '@type': 'Person', name: 'Ben Baldwin' },
        reviewBody: 'Great guy, and very helpful. Gives folks what they need.',
        reviewRating: { '@type': 'Rating', ratingValue: '5', bestRating: '5' },
      },
    ],
  },
];
---

<Layout
  title="David Arago — Fractional CTO & Technology Leader | AraGrow LLC"
  description="David Arago | AraGrow LLC — Fractional CTO services, AI integration, web development, and scalable tech solutions for growing businesses in Minneapolis, MN."
  structuredData={structuredData}
>
  <Nav />
  <Hero />
  <Services />
  <About />
  <Testimonials />
  <Blog />
  <Contact />
  <Footer />
</Layout>
