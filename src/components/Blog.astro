---
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
const posts = allPosts.slice(0, 3);
---

<section id="blog">
  <div class="container">
    <div class="reveal blog-header">
      <div>
        <div class="section-label">Insights</div>
        <h2 class="section-title">Latest from the <span class="grad-text">Blog</span></h2>
      </div>
      <a href="/blog" class="btn btn-outline">All Posts →</a>
    </div>
    <div class="blog-grid">
      {posts.map((post) => {
        const { title, date, excerpt, featuredImage, categories } = post.data;
        const slug = post.id.replace(/\.md$/, '');
        const shortExcerpt = excerpt ? excerpt.slice(0, 140) + (excerpt.length > 140 ? '…' : '') : '';
        const formattedDate = new Date(date).toLocaleDateString('en-US', {
          year: 'numeric', month: 'long', day: 'numeric',
        });
        return (
          <a href={`/blog/${slug}`} class="blog-card reveal" aria-label={`Read: ${title}`}>
            <div class="blog-img">
              {featuredImage
                ? <img src={featuredImage} alt={title} loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
                : <span aria-hidden="true">✍️</span>}
            </div>
            <div class="blog-body">
              {categories[0] && <div class="blog-category">{categories[0]}</div>}
              <h3>{title}</h3>
              <p>{shortExcerpt}</p>
              <div class="blog-meta">
                <time datetime={date}>{formattedDate}</time>
                <span class="blog-read">Read More →</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .blog-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .blog-header .btn {
    margin-top: 8px;
  }
</style>
